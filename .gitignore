# KiCad auto-save and backup files
*.kicad_pcb-bak
*.kicad_sch-bak
*.kicad_pro-bak
*-bak/
*_autosave-*
\#auto_saved_files\#

# KiCad lock files
*.lck

# KiCad local settings (machine-specific)
*.kicad_prl

# KiCad project-level cache
fp-info-cache
sym-lib-table
fp-lib-table

# Project-local footprint table for vendored SparkFun connector footprint
!fp-lib-table

# Fabrication outputs (generated, not source)
gerbers/
fab/
*.gbr
*.drl
*.dxf
*.pos
*.csv
*.xml

# Source purchasing BOMs
!bom/*.csv
!bom/*.xlsx

# Export outputs
*.pdf
*.svg
*.png
*.step
*.wrl
*.3dshapes/

# Allow docs to override the above
!docs/**/*.pdf
!docs/**/*.png
!docs/**/*.svg

# Project-local 3D CAD assets
!models/
!models/step/
!models/step/*.step
!models/step/*.zip
!exports/
!exports/step/
!exports/step/*.step

# Python cache (for KiCad scripting)
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*~
.vscode/settings.json
*-backups/
*.dsn
.history/
*.ses
